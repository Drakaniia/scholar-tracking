generator client {
  provider   = "prisma-client-js"
  engineType = "js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int        @id @default(autoincrement()) @map("user_id")
  username            String     @unique
  email               String     @unique
  passwordHash        String     @map("password_hash")
  firstName           String     @map("first_name")
  lastName            String     @map("last_name")
  role                String     @default("STAFF")
  status              String     @default("ACTIVE")
  lastLogin           DateTime?  @map("last_login")
  passwordChangedAt   DateTime   @default(now()) @map("password_changed_at")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  auditLogs           AuditLog[]
  backups             Backup[]
  sessions            Session[]

  @@map("users")
}

model Session {
  id        String   @id @map("session_id")
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id           Int      @id @default(autoincrement()) @map("log_id")
  userId       Int?     @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   Int?     @map("resource_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Student {
  createdAt        DateTime             @default(now()) @map("created_at")
  program          String
  status           String
  id               Int                  @id @default(autoincrement()) @map("student_id")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  yearLevel        String               @map("year_level")
  firstName        String               @map("first_name")
  gradeLevel       String               @map("grade_level")
  lastName         String               @map("last_name")
  middleInitial    String?              @map("middle_initial")
  birthDate        DateTime?            @map("birth_date")
  graduatedAt      DateTime?            @map("graduated_at")
  graduationStatus String?              @default("Active") @map("graduation_status")
  isArchived       Boolean              @default(false) @map("is_archived")
  termType         String               @default("SEMESTER") @map("term_type")
  disbursements    Disbursement[]
  fees             StudentFees[]
  scholarships     StudentScholarship[]

  @@index([lastName, firstName])
  @@index([gradeLevel, status])
  @@index([program])
  @@index([isArchived])
  @@index([graduationStatus])
  @@map("students")
}

model StudentScholarship {
  id                Int         @id @default(autoincrement()) @map("student_scholarship_id")
  studentId         Int         @map("student_id")
  scholarshipId     Int         @map("scholarship_id")
  awardDate         DateTime    @map("award_date")
  startTerm         String      @map("start_term")
  endTerm           String      @map("end_term")
  grantAmount       Decimal     @map("grant_amount") @db.Decimal(10, 2)
  grantType         String      @default("FULL") @map("grant_type") // FULL, TUITION_ONLY, MISC_ONLY, LAB_ONLY, NONE
  scholarshipStatus String      @map("scholarship_status")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  scholarship       Scholarship @relation(fields: [scholarshipId], references: [id])
  student           Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, scholarshipId])
  @@index([studentId])
  @@index([scholarshipId])
  @@index([scholarshipStatus])
  @@index([grantType])
  @@map("student_scholarships")
}

model Scholarship {
  type                String
  amount              Decimal              @db.Decimal(10, 2)
  createdAt           DateTime             @default(now()) @map("created_at")
  requirements        String?
  id                  Int                  @id @default(autoincrement()) @map("scholarship_id")
  scholarshipName     String               @map("scholarship_name")
  sponsor             String
  status              String
  updatedAt           DateTime             @updatedAt @map("updated_at")
  source              String               @default("INTERNAL")
  eligibleGradeLevels String               @map("eligible_grade_levels")
  isArchived          Boolean              @default(false) @map("is_archived")
  eligiblePrograms    String?              @map("eligible_programs")
  grantType           String               @default("FULL") @map("grant_type") // FULL, TUITION_ONLY, MISC_ONLY, LAB_ONLY, NONE
  coversTuition       Boolean              @default(false) @map("covers_tuition")
  coversMiscellaneous Boolean              @default(false) @map("covers_miscellaneous")
  coversLaboratory    Boolean              @default(false) @map("covers_laboratory")
  coversOther         Boolean              @default(false) @map("covers_other")
  otherFeeName        String?              @map("other_fee_name")
  tuitionFee          Decimal              @default(0) @map("tuition_fee") @db.Decimal(10, 2)
  miscellaneousFee    Decimal              @default(0) @map("miscellaneous_fee") @db.Decimal(10, 2)
  laboratoryFee       Decimal              @default(0) @map("laboratory_fee") @db.Decimal(10, 2)
  otherFee            Decimal              @default(0) @map("other_fee") @db.Decimal(10, 2)
  amountSubsidy       Decimal              @default(0) @map("amount_subsidy") @db.Decimal(10, 2)
  percentSubsidy      Decimal              @default(0) @map("percent_subsidy") @db.Decimal(5, 2)
  disbursements       Disbursement[]
  students            StudentScholarship[]

  @@index([type])
  @@index([source])
  @@index([status])
  @@index([isArchived])
  @@index([grantType])
  @@map("scholarships")
}

model Disbursement {
  id               Int         @id @default(autoincrement()) @map("disbursement_id")
  disbursementDate DateTime    @map("disbursement_date")
  amount           Decimal     @db.Decimal(10, 2)
  term             String
  method           String
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  remarks          String?
  scholarshipId    Int         @map("scholarship_id")
  studentId        Int         @map("student_id")
  scholarship      Scholarship @relation(fields: [scholarshipId], references: [id])
  student          Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("disbursements")
}

model StudentFees {
  id               Int      @id @default(autoincrement()) @map("fees_id")
  studentId        Int      @map("student_id")
  tuitionFee       Decimal  @map("tuition_fee") @db.Decimal(10, 2)
  otherFee         Decimal  @map("other_fee") @db.Decimal(10, 2)
  miscellaneousFee Decimal  @map("miscellaneous_fee") @db.Decimal(10, 2)
  laboratoryFee    Decimal  @map("laboratory_fee") @db.Decimal(10, 2)
  amountSubsidy    Decimal  @map("amount_subsidy") @db.Decimal(10, 2)
  percentSubsidy   Decimal  @map("percent_subsidy") @db.Decimal(5, 2) // Computed: (amountSubsidy / totalFees) * 100
  term             String
  academicYear     String   @map("academic_year")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_fees")
}

model Backup {
  id               Int      @id @default(autoincrement()) @map("backup_id")
  tableName        String   @map("table_name")
  recordId         Int      @map("record_id")
  operation        String   @map("operation")
  oldValue         Json     @map("old_value")
  createdAt        DateTime @default(now()) @map("created_at")
  performedBy      Int?     @map("performed_by")
  operationContext String   @map("operation_context")
  user             User?    @relation(fields: [performedBy], references: [id])

  @@index([tableName])
  @@index([recordId])
  @@index([createdAt])
  @@map("backups")
}
